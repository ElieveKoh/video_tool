#!/bin/bash

# Video Tool v6.0.4 Launcher
# 앱 버전 (릴리즈할 때 함께 갱신)
APP_VERSION="6.0.4"
# GitHub 저장소
GITHUB_REPO="ElieveKoh/video_tool"

# 앱 번들 내부 경로
SCRIPT_DIR="$(cd "$(dirname "$0")/../Resources" && pwd)"
LAUNCHER_SCRIPT="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
APP_BUNDLE_DIR="$(cd "$(dirname "$0")/../.." && pwd)"

# --run 플래그가 없으면 터미널에서 실행
if [ "$1" != "--run" ]; then
    osascript -e "
    tell application \"Terminal\"
        activate
        do script \"'$LAUNCHER_SCRIPT' --run\"
    end tell
    "
    exit 0
fi

# 실제 실행
APP_DIR="$SCRIPT_DIR"
cd "$APP_DIR"
RUNTIME_ROOT="$HOME/Library/Application Support/VideoTool"
RUNTIME_BIN_DIR="$RUNTIME_ROOT/bin"
RUNTIME_VENV_DIR="$RUNTIME_ROOT/venv"
RUNTIME_CACHE_DIR="$HOME/Library/Caches/VideoTool"

mkdir -p "$RUNTIME_ROOT" "$RUNTIME_BIN_DIR" "$RUNTIME_CACHE_DIR" 2>/dev/null || true

check_and_apply_update() {
    if [ -z "$GITHUB_REPO" ] || [ "$GITHUB_REPO" = "OWNER/REPO" ]; then
        echo "ℹ️  자동 업데이트 저장소가 설정되지 않아 현재 버전으로 실행합니다."
        return 0
    fi

    local api_url="https://api.github.com/repos/${GITHUB_REPO}/releases/latest"
    local release_json
    release_json="$(curl -fsSL "$api_url" 2>/dev/null)"

    if [ -z "$release_json" ]; then
        echo "ℹ️  업데이트 서버에 연결할 수 없어 현재 버전으로 실행합니다."
        return 0
    fi

    local latest_tag
    latest_tag="$(python3 - <<'PY' "$release_json"
import json, sys
try:
    data = json.loads(sys.argv[1])
    print(data.get("tag_name", "").strip())
except Exception:
    print("")
PY
)"

    if [ -z "$latest_tag" ]; then
        return 0
    fi

    local latest_version="${latest_tag#v}"
    local needs_update
    needs_update="$(python3 - <<'PY' "$APP_VERSION" "$latest_version"
import re, sys
def parse(v: str):
    nums = re.findall(r"\d+", v)
    return [int(x) for x in nums] if nums else [0]
def cmp(a, b):
    n = max(len(a), len(b))
    a = a + [0] * (n - len(a))
    b = b + [0] * (n - len(b))
    return (a > b) - (a < b)
print("yes" if cmp(parse(sys.argv[1]), parse(sys.argv[2])) < 0 else "no")
PY
)"

    if [ "$needs_update" != "yes" ]; then
        return 0
    fi

    echo ""
    echo "🆕 새 버전이 있습니다!"
    echo "   현재: v$APP_VERSION"
    echo "   최신: $latest_tag"
    read -r -p "지금 업데이트할까요? [Y/n] " answer
    case "$answer" in
        [Nn]*)
            echo "⏭️  업데이트를 건너뜁니다."
            return 0
            ;;
    esac

    local download_url
    download_url="$(python3 - <<'PY' "$release_json"
import json, sys
try:
    data = json.loads(sys.argv[1])
    assets = data.get("assets", [])
    preferred = None
    fallback = None
    for a in assets:
        name = str(a.get("name", "")).lower()
        url = a.get("browser_download_url", "")
        if not url:
            continue
        if name.endswith(".zip"):
            if "mac" in name or "video" in name or "tool" in name:
                preferred = url
                break
            if fallback is None:
                fallback = url
    print(preferred or fallback or data.get("zipball_url", ""))
except Exception:
    print("")
PY
)"

    if [ -z "$download_url" ]; then
        echo "❌ 다운로드 URL을 찾지 못했습니다."
        return 0
    fi

    local tmp_dir="$RUNTIME_CACHE_DIR/update_tmp"
    rm -rf "$tmp_dir"
    mkdir -p "$tmp_dir"

    echo "📥 업데이트 다운로드 중..."
    if ! curl -fL "$download_url" -o "$tmp_dir/update.zip"; then
        echo "❌ 업데이트 다운로드 실패"
        rm -rf "$tmp_dir"
        return 0
    fi

    if ! unzip -q "$tmp_dir/update.zip" -d "$tmp_dir/extracted"; then
        echo "❌ 업데이트 압축 해제 실패"
        rm -rf "$tmp_dir"
        return 0
    fi

    local src_dir=""
    if [ -d "$tmp_dir/extracted/VideoTool.app" ]; then
        src_dir="$tmp_dir/extracted/VideoTool.app"
    elif [ -f "$tmp_dir/extracted/Contents/MacOS/VideoTool" ]; then
        src_dir="$tmp_dir/extracted"
    else
        for candidate in "$tmp_dir/extracted"/*; do
            if [ -d "$candidate/VideoTool.app" ]; then
                src_dir="$candidate/VideoTool.app"
                break
            fi
            if [ -f "$candidate/Contents/MacOS/VideoTool" ]; then
                src_dir="$candidate"
                break
            fi
        done
    fi

    if [ -z "$src_dir" ]; then
        echo "❌ 업데이트 파일 구조를 확인할 수 없습니다."
        rm -rf "$tmp_dir"
        return 0
    fi

    if ! command -v rsync >/dev/null 2>&1; then
        echo "❌ rsync가 없어 업데이트를 적용할 수 없습니다."
        rm -rf "$tmp_dir"
        return 0
    fi

    echo "📦 업데이트 적용 중..."
    if ! rsync -a \
        --exclude "Contents/Resources/venv/" \
        --exclude "Contents/Resources/bin/" \
        --exclude "Contents/Resources/converted_*/" \
        --exclude "Contents/Resources/youtube_downloads/" \
        --exclude ".update_tmp/" \
        "$src_dir/" "$APP_BUNDLE_DIR/"; then
        echo "❌ 업데이트 적용 실패"
        rm -rf "$tmp_dir"
        return 0
    fi

    chmod +x "$APP_BUNDLE_DIR/Contents/MacOS/VideoTool" 2>/dev/null || true
    rm -rf "$tmp_dir"

    echo "✅ 업데이트 완료! 최신 버전으로 다시 시작합니다."
    echo "ℹ️ 업데이트 직후 화면이 비면 브라우저에서 Cmd+Shift+R로 새로고침하세요."
    exec "$LAUNCHER_SCRIPT" --run
}

# Python 경로 찾기 함수 (Skips25 방식 적용)
find_python() {
    # 가능한 Python 경로들을 순서대로 시도
    local python_paths=(
        "/usr/bin/python3"
        "/usr/local/bin/python3"
        "/opt/homebrew/bin/python3"
        "/Library/Frameworks/Python.framework/Versions/3.12/bin/python3"
        "/Library/Frameworks/Python.framework/Versions/3.11/bin/python3"
        "/Library/Frameworks/Python.framework/Versions/3.10/bin/python3"
        "$(which python3 2>/dev/null)"
    )

    for python_path in "${python_paths[@]}"; do
        if [[ -n "$python_path" && -x "$python_path" ]]; then
            echo "$python_path"
            return 0
        fi
    done

    # PATH에서 python3 찾기
    if command -v python3 >/dev/null 2>&1; then
        echo "python3"
        return 0
    fi

    return 1
}

# 시작 메시지
echo "🎥 Video Tool v6.0"
echo "===================="
echo ""

# 보안 해제
xattr -rd com.apple.quarantine "$APP_DIR" 2>/dev/null || true

# Python3 확인
echo "🔍 Python 찾는 중..."
PYTHON_CMD=$(find_python)

if [[ -z "$PYTHON_CMD" ]]; then
    echo "❌ Python3를 찾을 수 없습니다."
    osascript -e 'display dialog "❌ Python3를 찾을 수 없습니다.\n\nhttps://python.org 에서 Python을 설치해주세요." buttons {"확인"} default button "확인" with icon stop'
    exit 1
fi

echo "✅ Python 발견: $PYTHON_CMD"

check_and_apply_update

# FFmpeg 확인 (시스템 우선, 런타임 폴더 보조)
if command -v ffmpeg &> /dev/null || [ -f "$RUNTIME_BIN_DIR/ffmpeg" ]; then
    echo "✅ FFmpeg 이미 설치됨"
else
    echo "📦 FFmpeg 다운로드 중..."
    mkdir -p "$RUNTIME_BIN_DIR"
    curl -L "https://evermeet.cx/ffmpeg/getrelease/zip" -o /tmp/ffmpeg.zip
    unzip -q /tmp/ffmpeg.zip -d "$RUNTIME_BIN_DIR/"
    rm /tmp/ffmpeg.zip
    chmod +x "$RUNTIME_BIN_DIR/ffmpeg"
    echo "✅ FFmpeg 설치 완료"
fi

# yt-dlp 확인 (시스템 우선, 런타임 폴더 보조)
if command -v yt-dlp &> /dev/null || [ -f "$RUNTIME_BIN_DIR/yt-dlp" ]; then
    echo "✅ yt-dlp 이미 설치됨"
else
    echo "📦 yt-dlp 다운로드 중..."
    mkdir -p "$RUNTIME_BIN_DIR"
    curl -L https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp_macos -o "$RUNTIME_BIN_DIR/yt-dlp"
    chmod +x "$RUNTIME_BIN_DIR/yt-dlp"
    echo "✅ yt-dlp 설치 완료"
fi

# PATH 설정
export PATH="$RUNTIME_BIN_DIR:$PATH"

# Python 가상환경 (앱 번들이 아닌 사용자 홈 경로 사용)
if [ -d "$RUNTIME_VENV_DIR" ]; then
    echo "✅ Python 가상환경 이미 존재"
else
    echo "📦 Python 가상환경 생성 중..."
    if "$PYTHON_CMD" -m venv "$RUNTIME_VENV_DIR"; then
        echo "✅ Python 가상환경 생성 완료"
    else
        echo "❌ Python 가상환경 생성 실패"
        osascript -e 'display dialog "❌ Python 가상환경을 만들 수 없습니다.\n\n디스크 권한 또는 저장공간을 확인해주세요." buttons {"확인"} default button "확인" with icon stop' 2>/dev/null || true
        exit 1
    fi
fi

if [ -f "$RUNTIME_VENV_DIR/bin/activate" ]; then
    source "$RUNTIME_VENV_DIR/bin/activate"
else
    echo "❌ Python 실행 환경을 찾을 수 없습니다."
    exit 1
fi

# pip 업그레이드
echo "📦 pip 업그레이드 중..."
python -m pip install --upgrade pip --quiet 2>&1 | grep -v "WARNING" || true

# Streamlit 확인 및 설치
if python -c "import streamlit" 2>/dev/null; then
    echo "✅ Streamlit 이미 설치됨"
else
    echo "📦 Streamlit 설치 중..."
    # pyarrow 없이 streamlit만 설치
    python -m pip install streamlit --no-cache-dir 2>&1 | grep -E "Successfully|ERROR" || echo "설치 중..."

    # 설치 확인
    if python -c "import streamlit" 2>/dev/null; then
        echo "✅ Streamlit 설치 완료"
    else
        echo "❌ Streamlit 설치 실패"
        exit 1
    fi
fi

# 포트 찾기
PORT=8601
while lsof -Pi :$PORT -sTCP:LISTEN -t >/dev/null 2>&1; do
    PORT=$((PORT + 1))
done

echo "🚀 Video Tool 실행 중... (포트 $PORT)"

# Streamlit 실행
python -m streamlit run "$APP_DIR/video_converter_app.py" \
    --server.headless=false \
    --server.port=$PORT \
    --server.address=127.0.0.1 \
    --browser.serverAddress=127.0.0.1 \
    --server.fileWatcherType=none
